# NyaySarthi AI v2 - Environment Configuration
# Copy this file to .env in both backend/ and root directories and fill in your API keys

# ============================================
# Google Gemini API (get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# Groq API (get from https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# ============================================
# Ollama (Local LLM - leave default if running locally)
OLLAMA_BASE_URL=http://localhost:11434

# ============================================
# App Settings
APP_NAME=NyaySarthi AI
DEBUG=False
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================
# Default Models
DEFAULT_PROVIDER=gemini
DEFAULT_GEMINI_MODEL=gemini-2.5-flash-preview-05-20
DEFAULT_GROQ_MODEL=llama-3.3-70b-versatile
DEFAULT_OLLAMA_MODEL=llama3.2
